# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# CRYPTOCOMPARE_API_KEY: API Key for CryptoCompare News API.
CRYPTOCOMPARE_API_KEY=MY_CRYPTOCOMPARE_API_KEY

# COINMARKETCAL_API_KEY: API Key for CoinMarketCal API.
COINMARKETCAL_API_KEY=MY_COINMARKETCAL_API_KEY

# FRED_API_KEY: API Key for FRED (St. Louis Fed) Economic Data API.
FRED_API_KEY=MY_FRED_API_KEY

# FINNHUB_API_KEY: API Key for Finnhub Economic Calendar API.
FINNHUB_API_KEY=MY_FINNHUB_API_KEY
